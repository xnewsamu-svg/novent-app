  <tr><td>Condiciones</td><td>2 evaluadores (comparison 12 operadores, logical AND/OR/NOT)</td></tr>
  <tr><td>Executors</td><td>5 (trigger, condition, action, delay, end)</td></tr>
  <tr><td>Servicios</td><td>3 (workflow, execution, scheduler) + 1 adapter</td></tr>
  <tr><td>Validadores</td><td>3 (workflow, node, edge)</td></tr>
</table>

